{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "pip install -r requirements-prod.txt && cd src && python manage.py migrate --noinput && python manage.py collectstatic --noinput --clear",
  "functions": {
    "src/core/wsgi.py": {
      "maxDuration": 60,
      "includeFiles": "{static/**,**/*.html}"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "src/core/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "core.settings.prod",
    "VERCEL": "1"
  }
}