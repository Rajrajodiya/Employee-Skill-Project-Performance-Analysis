{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "esppa",
  "buildCommand": "cd src && python manage.py collectstatic --noinput --clear",
  "functions": {
    "src/core/wsgi.py": {
      "maxDuration": 60,
      "memory": 1024,
      "excludeFiles": "{tests/**,__pycache__/**,logs/**,DATASET/**,media/**,docs/**,.dvc/**,venv/**}"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/core/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "core.settings.prod",
    "DJANGO_ENV": "prod",
    "VERCEL": "1"
  }
}
