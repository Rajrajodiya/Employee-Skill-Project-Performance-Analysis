{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "pip install -r requirements-prod.txt && cd src && python manage.py collectstatic --noinput --clear",
  "functions": {
    "src/core/wsgi.py": {
      "maxDuration": 60,
      "memory": 1024,
      "excludeFiles": "{tests/**,__pycache__/**,*.pyc,*.pyo,logs/**,DATASET/**,media/**,docs/**,.dvc/**,venv/**,node_modules/**,staticfiles/**,*.sqlite3,*.egg-info/**,requirements-dev.txt,.github/**,Makefile,*.bat,package*.json,pyproject.toml,.gitignore}"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "src/core/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "core.settings.prod",
    "DJANGO_ENV": "prod",
    "VERCEL": "1",
    "SECRET_KEY": "vercel-build-placeholder-change-in-dashboard",
    "VERCEL_SUPPORT_LARGE_FUNCTIONS": "1"
  }
}
